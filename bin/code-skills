#!/usr/bin/env bash
# code-skills CLI · 调度器 (opencli-aligned)
#
# 命令树:
#   validate                                     校验 skill 结构
#   install [--symlink|--copy]                   安装 skill 到 ~/.claude/skills/
#   uninstall                                    卸载 skill 软链
#   list                                         列出本仓库 skill
#   doctor [--json]                              检测外部工具(jq, node, browser-use, remotion 等)
#   describe [--json]                            输出 CLI 命令树 schema(opencli)
#   version [--json]                             显示版本
#   plugin <list|status|install|uninstall>       管理嵌入式 plugin
#   help [<command>]                             显示帮助
#
# 通用 flag (所有子命令支持):
#   --help / -h, --json, --quiet / -q, --verbose / -v, --no-color, --dry-run, --yes / -y
#
# 退出码:
#   0 success / 1 runtime / 2 usage / 3 dependency / 130 interrupted

set -e

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CMD="${1:-help}"
shift || true

case "$CMD" in
  validate|v)
    exec python3 "$ROOT/scripts/validate.py" "$@"
    ;;
  install|i)
    exec python3 "$ROOT/scripts/install.py" "$@"
    ;;
  uninstall|un)
    exec python3 "$ROOT/scripts/install.py" --uninstall "$@"
    ;;
  list|ls)
    exec python3 "$ROOT/scripts/list_skills.py" "$@"
    ;;
  doctor|dr)
    exec python3 "$ROOT/scripts/doctor.py" "$@"
    ;;
  describe|schema)
    exec python3 "$ROOT/scripts/describe.py" "$@"
    ;;
  version|--version|-V)
    if [[ "${1:-}" == "--json" ]]; then
      echo '{"ok": true, "data": {"version": "0.2.0"}}'
    else
      echo "code-skills 0.2.0"
    fi
    ;;
  plugin|p)
    exec python3 "$ROOT/scripts/plugin.py" "$@"
    ;;
  demo)
    exec python3 "$ROOT/scripts/demo.py" "$@"
    ;;
  browser)
    exec python3 "$ROOT/scripts/browser.py" "$@"
    ;;
  cli-init|init)
    exec python3 "$ROOT/scripts/cli_init.py" "$@"
    ;;
  vendor|v)
    exec python3 "$ROOT/scripts/vendor.py" "$@"
    ;;
  help|-h|--help|"")
    cat <<'EOF'
code-skills CLI · 综合开发技能套件 (opencli-aligned)

USAGE:
  bin/code-skills <command> [flags] [args]

COMMANDS:
  validate              校验所有 skill 结构与一致性
  install               安装 skill 到 ~/.claude/skills/
    --symlink             软链(默认),源更新即生效
    --copy                复制
  uninstall             卸载本仓库装上去的链
  list                  列出本仓库的 skill
  doctor                检测外部工具(jq/node/python/browser-use/remotion 等)
  describe              输出 CLI 命令树 schema(对齐 opencli,可被 agent 消费)
  version               显示版本
  plugin <subcmd>       管理嵌入式 plugin
    list                  列出可装的 plugin
    status [<name>]       查看安装状态
    install <name|--all>  安装(默认软链)
    uninstall <name|--all>
  demo <subcmd>         Remotion passthrough(init/render/studio/preview)
  browser <subcmd>      browser-use passthrough(run/version/doctor)
  cli-init <name>       Scaffold 一个符合 opencli 规范的新 CLI 项目
  vendor <subcmd>       管理 vendor/cowork/ (19 个领域插件 / 67+ skill)
    list                  列出 plugin + skill 计数
    status [<plugin>]     查看激活状态
    install <plugin|--all-vendored> [--copy]  装到 ~/.claude/plugins/code-skills-vendor/
    uninstall <plugin>    卸载
    diff                  对比 vendor vs 上游 Cowork cache
    sync [--dry-run]      从上游同步更新
  help                  显示本帮助

COMMON FLAGS (every subcommand):
  --help / -h           显示子命令帮助
  --json                输出机器可读 JSON
  --quiet / -q          静默
  --verbose / -v        详细日志
  --no-color            禁用颜色
  --dry-run             演练
  --yes / -y            跳过确认

EXIT CODES:
  0  success
  1  runtime error
  2  usage error
  3  missing dependency
  130 interrupted

EXAMPLES:
  bin/code-skills validate
  bin/code-skills install --symlink
  bin/code-skills doctor
  bin/code-skills describe --json | jq '.commands[].name'
  bin/code-skills plugin install ralph-loop
  bin/code-skills plugin install --all
  bin/code-skills plugin status

INTEGRATIONS:
  - 嵌入式 plugin: ralph-loop, code-simplifier (Anthropic, Apache-2.0, 见 NOTICE)
  - 借鉴: opencli, CLI-Anything, browser-use, remotion, taste-skill 等
EOF
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    echo "Run 'bin/code-skills help' for usage." >&2
    exit 2
    ;;
esac
